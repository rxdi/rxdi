{
  "name": "@rxdi/graphql",
  "version": "0.7.241",
  "repository": {
    "type": "git",
    "url": "https://github.com/rxdi/graphql"
  },
  "scripts": {
    "lint": "tslint -c tslint.json 'development/**/*.{ts,tsx}'",
    "lint:fix": "tslint -c tslint.json 'development/**/*.{ts,tsx}' --fix",
    "build": "tsc",
    "test": "jest"
  },
  "author": {
    "name": "Kristian Tachev(Stradivario)",
    "email": "kristiqn.tachev@gmail.com"
  },
  "keywords": [
    "graphql",
    "gapi",
    "node"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/rxdi/graphql/issues"
  },
  "homepage": "https://github.com/rxdi/graphql#readme",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "typings": "./dist/index.d.ts",
  "dependencies": {
    "@hapi/boom": "^10.0.1"
  },
  "devDependencies": {
    "@rxdi/core": "^0.7.241",
    "@rxdi/hapi": "^0.7.241",
    "graphql": "^16.12.0",
    "@types/graphql": "^14.5.0",
    "@types/node": "^25.0.3",
    "rxjs": "^7.8.2",
    "tslint": "^5.20.1",
    "tslint-language-service": "^0.9.9",
    "typescript": "^5.9.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "rootDir": "./",
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true,
          "diagnostics": false
        }
      ]
    },
    "testRegex": "/src/*/.*\\.spec\\.(ts|tsx|js)$",
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  }
}